# MongoDB connection string (Atlas recommended)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# JWT secret for signing tokens (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here

# Google Gemini API key from https://ai.google.dev/
GOOGLE_GENAI_API_KEY=your_gemini_api_key_here

# Frontend URL for CORS (set to your Vercel URL in production)
CORS_ORIGIN=http://localhost:5173

# Port (optional, defaults to 3000)
PORT=3000
